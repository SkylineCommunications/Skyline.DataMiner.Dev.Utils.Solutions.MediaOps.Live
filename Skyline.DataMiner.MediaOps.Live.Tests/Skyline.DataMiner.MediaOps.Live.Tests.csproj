		<PackageReference Include="Skyline.DataMiner.Dev.Automation" Version="10.5.6" />
		<PackageReference Include="FluentAssertions" Version="7.2.0" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\Skyline.DataMiner.MediaOps.Live.UnitTesting\Skyline.DataMiner.MediaOps.Live.UnitTesting.csproj" />
